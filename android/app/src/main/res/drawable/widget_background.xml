<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow/border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp"/>
            <solid android:color="#33AADDFF"/>
        </shape>
    </item>
    <!-- Main background -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp"/>
            <gradient
                android:type="linear"
                android:startColor="#E0122B55"
                android:endColor="#E01A4A8A"
                android:angle="135"/>
        </shape>
    </item>
    <!-- Top highlight (glass shimmer — 상단 14dp 고정) -->
    <item android:bottom="30dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="20dp" android:topRightRadius="20dp"/>
            <gradient
                android:type="linear"
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"/>
        </shape>
    </item>
</layer-list>
